#!/usr/bin/ucode
'use strict';

import { cursor } from 'uci';

const methods = {
	config_get: {
		args: {},
		call: function() {
			const hpuci = cursor();
			let values = {};

			hpuci.load('homeproxy');
			hpuci.foreach('homeproxy', null, (cfg) => {
				values[cfg['.name']] = cfg;
			});

			return { values };
		}
	}
};

return { 'luci.homeproxy_config': methods };
